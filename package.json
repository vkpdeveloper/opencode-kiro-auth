    "url": "https://github.com/vkpdeveloper/opencode-kiro-auth.git"
  },
  "homepage": "https://github.com/vkpdeveloper/opencode-kiro-auth#readme",
  "bugs": {
    "url": "https://github.com/vkpdeveloper/opencode-kiro-auth/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@opencode-ai/plugin": "^1.1.48",
    "@types/node": "^22.0.0",
    "bun-types": "^1.1.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
