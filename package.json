{
  "name": "opencode-kiro-auth",
  "version": "0.0.1",
  "description": "OpenCode plugin that adds Kiro auth and model access",
  "type": "module",
  "main": "dist/index.js",
  "module": "index.ts",
  "files": [
    "dist",
    "index.ts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "plugin",
    "kiro",
    "oauth",
    "aws",
    "codewhisperer"
  ],
  "repository": {
